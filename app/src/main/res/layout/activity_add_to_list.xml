<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightWhite"
    tools:context=".AddToListActivity">

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        tools:ignore="MissingConstraints">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="20dp"
            android:layout_height="30dp"
            android:layout_marginStart="12dp"
            android:layout_marginVertical="12dp"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_back"
            android:src="@drawable/ic_back"/>
    </LinearLayout>

<!--    <LinearLayout-->
<!--        android:id="@+id/titleBar"-->
<!--        android:layout_width="0dp"-->
<!--        android:layout_height="wrap_content"-->
<!--        android:orientation="vertical"-->
<!--        android:layout_margin="15dp"-->
<!--        app:layout_constraintTop_toBottomOf="@id/topBar"-->
<!--        app:layout_constraintStart_toStartOf="parent"-->
<!--        app:layout_constraintEnd_toEndOf="parent">-->

<!--        -->
<!--    </LinearLayout>-->

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp"
            android:paddingBottom="10dp">
            <TextView
                android:id="@+id/tvFantasy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/curate_heading"
                android:fontFamily="@font/jakarta_bold"
                android:padding="8dp"
                android:backgroundTint="@color/skyBlue"
                android:background="@drawable/rounded_search"
                app:drawableStartCompat="@drawable/ic_collection1"
                android:drawablePadding="8dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_new_list_title"
                android:textColor="@color/black"
                android:textSize="28sp"
                android:fontFamily="@font/jakarta_extra_bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:text="@string/create_list_subtitle"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:fontFamily="@font/jakarta_medium"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="10dp"
                android:padding="10dp"
                android:backgroundTint="@color/lighterGray"
                android:background="@drawable/rounded_btn_container">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_title_field"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/navyBlue"
                    android:fontFamily="@font/jakarta_extra_bold"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_list_title_example"
                    android:fontFamily="@font/jakarta_medium"
                    android:background="@drawable/rounded_input"
                    android:padding="10dp"
                    android:layout_marginBottom="10dp"
                    android:inputType="text"
                    android:importantForAutofill="no"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_description_field"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/jakarta_extra_bold"
                    android:textColor="@color/navyBlue"
                    android:layout_marginBottom="6dp"/>
                <EditText
                    android:id="@+id/description"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="@string/hint_list_description_alt"
                    android:background="@drawable/rounded_input"
                    android:fontFamily="@font/jakarta_medium"
                    android:padding="10dp"
                    android:layout_marginBottom="10dp"
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:scrollbars="vertical"
                    android:importantForAutofill="no"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="10dp"
                android:padding="10dp"
                android:backgroundTint="@color/lighterGray"
                android:background="@drawable/rounded_btn_container">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_cover_image"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/navyBlue"
                    android:fontFamily="@font/jakarta_extra_bold"
                    android:layout_marginBottom="6dp"/>
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/rounded_input"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/ivCoverImage"
                        android:layout_width="365dp"
                        android:layout_height="183dp"
                        android:contentDescription="@string/label_cover_image"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/tvCoverHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/tap_upload_image"
                        android:textColor="@color/darkGray"
                        android:textSize="14sp"
                        android:fontFamily="@font/jakarta_extra_bold"
                        android:layout_gravity="center"/>
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cover_upload_hint"
                    android:textSize="12sp"
                    android:fontFamily="@font/jakarta_bold"
                    android:layout_marginTop="4dp"
                    android:layout_gravity="start"/>
            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/section_select_books"
                android:textSize="24sp"
                android:fontFamily="@font/jakarta_extra_bold"
                android:textColor="@color/black"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/select_books_subtitle"
                android:textSize="15sp"
                android:fontFamily="@font/jakarta_medium"
                android:layout_marginBottom="6dp"
                android:textColor="@color/black"/>
<!--            <EditText-->
<!--                android:id="@+id/etSearch"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:hint="Search your library"-->
<!--                android:background="@drawable/rounded_search"-->
<!--                android:padding="10dp"-->
<!--                android:inputType="text"-->
<!--                android:drawableStart="@drawable/ic_search"-->
<!--                android:drawablePadding="8dp"/>-->
<!--            the clicked boook must be added here-->
<!--            <androidx.recyclerview.widget.RecyclerView-->
<!--                android:id="@+id/rvSelectedBooks"-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_marginTop="10dp"-->
<!--                android:nestedScrollingEnabled="false"/>-->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvUserBooks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/addToCommunity"
                style="@style/Widget.Bookshell.Button.Gold"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/share_to_community"
                android:textSize="18sp"
                android:paddingVertical="14dp"
                android:backgroundTint="@color/lightBrown"
                app:icon="@drawable/ic_rocket"
                app:iconGravity="textStart"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/share_to_community_desc"
                android:textSize="12sp"
                android:layout_gravity="center"
                android:layout_marginBottom="10dp"
                android:textColor="@color/black"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:menu="@menu/bottom_nav"
        android:background="@color/white"
        app:itemIconTint="@color/bottom_nav_item_tint"
        app:itemTextColor="@color/bottom_nav_item_tint"
        app:labelVisibilityMode="labeled"/>

</androidx.constraintlayout.widget.ConstraintLayout>