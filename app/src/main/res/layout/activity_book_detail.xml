<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:backgroundTint="@color/lightWhite">
    <LinearLayout
        android:id="@+id/main"
        android:orientation="vertical"
        android:paddingVertical="1dp"
        android:paddingHorizontal="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="20dp"
            android:layout_height="30dp"
            android:layout_marginBottom="10dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/cd_back"
            android:src="@drawable/ic_back"/>
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivDetailImage"
            android:layout_width="260dp"
            android:layout_height="340dp"
            android:scaleType="centerCrop"
            android:layout_gravity="center"
            android:contentDescription="@string/cd_book_cover_detail"
            android:src="@android:drawable/ic_menu_gallery"
            app:shapeAppearanceOverlay="@style/singleBookImage" />
        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/placeholder_book_title"
            android:ellipsize="end"
            android:maxLines="2"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="@font/jakarta_extra_bold"
            android:textColor="@color/darkerGray"
            android:layout_marginTop="16dp" />
        <TextView
            android:id="@+id/tvAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_author"
            android:textSize="22sp"
            android:textStyle="italic"
            android:gravity="center"
            android:textColor="@color/navyBlue"
            android:fontFamily="@font/jakarta_bold_italic"
            android:layout_marginTop="16dp"/>
        <TextView
            android:id="@+id/tvCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:text="@string/label_genre_caps"
            android:fontFamily="@font/jakarta_medium"
            android:textColor="@color/black"
            android:backgroundTint="@color/lightBlue"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_reactions_container"
            android:layout_marginTop="16dp"/>

        <LinearLayout
            style="?android:attr/buttonBarStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:paddingVertical="6dp"
            android:paddingHorizontal="4dp"
            android:backgroundTint="#80F0F0F8"
            android:background="@drawable/rounded_btn_container">
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fillViewport="true"
                android:overScrollMode="never"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <Button
                        android:id="@+id/btnWantToRead"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:minHeight="48dp"
                        android:paddingHorizontal="12dp"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="none"
                        android:text="@string/status_want_to_read"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:fontFamily="@font/jakarta_bold"
                        android:backgroundTint="#80F0F0F8"
                        android:layout_marginEnd="4dp"/>
                    <Button
                        android:id="@+id/btnCurrentlyReading"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:minHeight="48dp"
                        android:paddingHorizontal="12dp"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="none"
                        android:text="@string/status_currently_reading"
                        android:textColor="@color/black"
                        android:textSize="13sp"
                        android:fontFamily="@font/jakarta_bold"
                        android:backgroundTint="#80F0F0F8"
                        android:layout_marginEnd="4dp"/>
                    <Button
                        android:id="@+id/btnCompleted"
                        style="?android:attr/buttonBarButtonStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="0dp"
                        android:minHeight="48dp"
                        android:paddingHorizontal="12dp"
                        android:gravity="center"
                        android:maxLines="2"
                        android:ellipsize="none"
                        android:text="@string/shelf_read"
                        android:textSize="13sp"
                        android:fontFamily="@font/jakarta_bold"
                        android:textColor="@color/black"
                        android:backgroundTint="#80F0F0F8"/>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llStatusButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:weightSum="3">
        </LinearLayout>

        <Button
            android:id="@+id/btnPreview"
            style="@style/Widget.Bookshell.Button.Gold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/lightBrown"
            android:text="@string/action_preview"
            android:textSize="16sp"
            android:fontFamily="@font/jakarta_bold"
            android:paddingVertical="14dp"
            app:icon="@drawable/ic_preview"
            app:iconGravity="textStart" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="18dp">
            <Button
                android:id="@+id/btnCreateList"
                style="@style/Widget.Bookshell.Button.Gold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/lightBrown"
                android:text="@string/action_create_list"
                android:textSize="16sp"
                android:fontFamily="@font/jakarta_bold"
                android:paddingVertical="14dp"
                android:layout_marginEnd="6dp"
                app:icon="@drawable/ic_add_list"
                app:iconGravity="textStart" />
            <Button
                android:id="@+id/btnAddToList"
                style="@style/Widget.Bookshell.Button.Gold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:backgroundTint="@color/lightBrown"
                android:text="@string/action_add_to_list"
                android:fontFamily="@font/jakarta_bold"
                android:textSize="16sp"
                android:paddingVertical="14dp"
                app:icon="@drawable/ic_add_list"
                app:iconGravity="textStart" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/section_quick_reactions"
            android:fontFamily="@font/jakarta_bold"
            android:layout_marginBottom="6dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#E6FFFFFF"
            android:background="@drawable/rounded_reactions_container">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/btnLike"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/cd_reaction_like"
                    android:src="@drawable/rc_like"/>
                <TextView
                    android:id="@+id/tvLikeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_gravity="center"
                    android:text="@string/zero"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/btnFire"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/reaction_fire"
                    android:src="@drawable/rc_fire"/>
                <TextView
                    android:id="@+id/tvFireCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="@string/zero"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/btnHeart"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/cd_reaction_heart"
                    android:src="@drawable/rc_heart"/>
                <TextView
                    android:id="@+id/tvHeartCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="@string/zero"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/btnSad"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/reaction_sad"
                    android:src="@drawable/rc_sad"/>
                <TextView
                    android:id="@+id/tvSadCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="@string/zero"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="8dp"
                android:orientation="vertical">
                <ImageView
                    android:id="@+id/btnAngry"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/reaction_angry"
                    android:src="@drawable/rc_angry"/>
                <TextView
                    android:id="@+id/tvAngryCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:text="@string/one"/>
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@drawable/rounded_cnt"
            android:clipToOutline="true"
            android:backgroundTint="#66F0F0F8"
            tools:ignore="NewApi">
            <View
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="-60dp"
                android:layout_marginEnd="-60dp"
                android:background="@drawable/circle_overlay"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/section_synopsis"
                    android:textSize="22sp"
                    android:fontFamily="@font/jakarta_bold"
                    android:textColor="@color/black"/>
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/placeholder_description"
                    android:fontFamily="@font/jakarta_light"
                    android:textSize="16sp"
                    android:layout_marginTop="16dp"
                    android:justificationMode="inter_word"
                    android:lineSpacingExtra="6dp"
                    tools:ignore="NewApi"/>
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_leave_review"
            android:textSize="24sp"
            android:fontFamily="@font/jakarta_bold"
            android:textColor="@color/black"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="10dp"
            android:padding="24dp"
            android:background="@drawable/rounded_cnt"
            android:backgroundTint="#4DDBDCE6">
            <RatingBar
                android:id="@+id/ratingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:progressTint="@color/yellow"
                android:secondaryProgressTint="@color/yellow"
                android:stepSize="1"/>

            <EditText
                android:id="@+id/etReview"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:hint="@string/hint_write_review"
                android:fontFamily="@font/jakarta_light"
                android:gravity="top|start"
                android:padding="12dp"
                android:inputType="textMultiLine"
                android:scrollbars="vertical"
                android:layout_marginBottom="8dp"
                android:background="@drawable/rounded_cntr"
                android:importantForAutofill="no"/>
            <Button
                android:id="@+id/btnSubmitReview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:gravity="end"
                android:textSize="18sp"
                android:paddingVertical="18dp"
                android:paddingHorizontal="32dp"
                android:backgroundTint="@color/navyBlue"
                android:text="@string/action_post_review"
                android:fontFamily="@font/jakarta_bold"/>
        </LinearLayout>


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_community_reviews"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:fontFamily="@font/jakarta_bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvNoReviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_reviews_available"
            android:fontFamily="@font/jakarta_light"
            android:textSize="16sp"
            android:visibility="gone"
            android:textColor="@color/darkerGray"
            android:layout_marginBottom="8dp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvReviews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</ScrollView>


