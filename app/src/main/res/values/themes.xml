<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.TestBooks1" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@color/lightWhite</item>
        <item name="android:editTextStyle">@style/Widget.Bookshell.EditText</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.TestBooks1" parent="Base.Theme.TestBooks1" />

    <style name="ShapeAppearance.Rounded" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.Rounded12" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <style name="ShapeAppearance.RoundedCircle" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Gold / tan primary actions: white label + icons (theme primary is purple; avoid inheriting it) -->
    <style name="Widget.Bookshell.Button.Gold" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="iconTint">@color/white</item>
    </style>
</resources>